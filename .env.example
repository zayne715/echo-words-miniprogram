CLOUD_ENV_ID=cloud1-xxxxxxxxxxxxxxxx
CLOUD_STORAGE_FILEID_ENV=cloud1-xxxxxxxxxxxxxxxx.xxxx-cloud1-xxxxxxxxxxxxxxxx-xxxxxxxxxx

# Cloud function environment variables (configure in WeChat Cloud console)
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key
BAIDU_TTS_PER=5971

DEEPSEEK_API_KEY=your_deepseek_api_key
ADMIN_ANALYTICS_TOKEN=replace_with_long_random_token
