page {
  background: #6366f1;
  height: 100vh;
  overflow: hidden;
  font-family: "Inter", "SF Pro Display", "Helvetica Neue", Arial, "PingFang SC", sans-serif;
}

.finish-r3-page {
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #6366f1;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 360ms ease-in-out, transform 420ms cubic-bezier(0.22, 0.61, 0.36, 1);
}

.finish-r3-page-entered {
  opacity: 1;
  transform: translateY(0);
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.emoji {
  font-size: 48px;
  line-height: 72px;
}

.title {
  margin-top: 20px;
  color: #ffffff;
  font-size: 44rpx;
  line-height: 66rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 10px;
  color: rgba(255, 255, 255, 0.7);
  font-size: 30rpx;
  line-height: 45rpx;
}
