page {
  background: #f5f7fa;
  min-height: 100vh;
  font-family: "SF Pro Display", "Inter", "Helvetica Neue", Arial, "PingFang SC", sans-serif;
}

.review-page {
  height: 100vh;
  transform: translateX(100%);
  transition: transform 220ms ease-out;
  box-sizing: border-box;
  background: #f5f7fa;
}

.review-page-entered {
  transform: translateX(0);
}

.page-scroll {
  height: 100vh;
}

.page-scroll-content {
  padding-bottom: 150px;
  box-sizing: border-box;
}

.top-bar {
  height: 40px;
  padding: 0 16px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 12px;
}

.circle-btn {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background: rgba(107, 114, 128, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-btn-light {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  opacity: 0.3;
  background: rgba(107, 114, 128, 0.08);
}

.circle-btn-light-active {
  opacity: 0.72;
  background: rgba(107, 114, 128, 0.18);
}

.circle-btn-disabled {
  pointer-events: none;
}

.circle-icon {
  width: 22px;
  height: 22px;
}

.reply-wrap {
  width: 18px;
  height: 18px;
  position: relative;
}

.reply-base {
  width: 18px;
  height: 18px;
}

.reply-arrow {
  width: 14px;
  height: 12px;
  position: absolute;
  left: 2px;
  top: 4px;
}

.header-progress {
  flex: 1;
  min-width: 0;
  height: 30px;
  background: #e5e7eb;
  border-radius: 15px;
  position: relative;
  overflow: hidden;
}

.header-progress-fill {
  height: 30px;
  border-radius: 15px;
  background: #10b981;
  transition: width 260ms ease;
}

.header-progress-text {
  position: absolute;
  left: 50%;
  top: 5px;
  transform: translateX(-50%);
  z-index: 1;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #374151;
  font-weight: 600;
  text-shadow: 0 0 5px rgba(255, 255, 255, 0.95), 0 0 10px rgba(255, 255, 255, 0.75);
}

.content-main {
  margin: 22px 20px 0;
  width: calc(100vw - 40px);
  box-sizing: border-box;
}

.word-title-row {
  height: 38px;
  display: flex;
  align-items: center;
}

.word-audio {
  width: 20px;
  height: 20px;
}

.word-title {
  margin-left: 8px;
  font-size: 68rpx;
  line-height: 74rpx;
  color: #1f2937;
  font-weight: 700;
}

.word-phonetic {
  margin-top: 8px;
  font-size: 34rpx;
  line-height: 52rpx;
  color: #9ca3af;
}

.bottom-actions-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 104px;
  padding: 12px 16px calc(env(safe-area-inset-bottom) + 12px);
  box-sizing: border-box;
  background: #f5f7fa;
  display: flex;
  gap: 10px;
}

.action-btn {
  flex: 1;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn-left {
  background: #fef3c7;
}

.action-btn-right {
  background: #10b981;
  box-shadow: 0 4px 8px rgba(16, 185, 129, 0.3);
}

.action-btn-left-text {
  color: #d97706;
  font-size: 34rpx;
  font-weight: 600;
}

.action-btn-right-text {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.btn-pressed {
  transform: scale(0.97);
}

.btn-release {
  transform: scale(1);
}

.btn-disabled {
  pointer-events: none;
}

/* iPhone Pro 视觉适配：与学习流程页保持一致的尺寸体系 */
.page-scroll-content {
  padding-bottom: 168px;
}

.top-bar {
  height: 44px;
  padding: 0 18px;
  gap: 14px;
}

.circle-btn {
  width: 44px;
  height: 44px;
  border-radius: 22px;
}

.circle-btn-light {
  width: 40px;
  height: 40px;
  border-radius: 20px;
}

.circle-icon {
  width: 24px;
  height: 24px;
}

.header-progress {
  height: 32px;
  border-radius: 16px;
}

.header-progress-fill {
  height: 32px;
  border-radius: 16px;
}

.header-progress-text {
  top: 6px;
  font-size: 28rpx;
  line-height: 40rpx;
}

.content-main {
  margin: 28px 18px 0;
  width: calc(100vw - 36px);
}

.word-audio {
  width: 22px;
  height: 22px;
}

.word-title {
  font-size: 74rpx;
  line-height: 80rpx;
}

.word-phonetic {
  font-size: 36rpx;
  line-height: 56rpx;
}

.bottom-actions-wrap {
  height: 112px;
  padding: 14px 18px calc(env(safe-area-inset-bottom) + 14px);
  gap: 12px;
}

.action-btn {
  height: 60px;
  border-radius: 18px;
}

.action-btn-left-text,
.action-btn-right-text {
  font-size: 36rpx;
}
