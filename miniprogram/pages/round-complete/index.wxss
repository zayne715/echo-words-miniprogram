page {
  background: #f5f7fa;
  min-height: 100vh;
  font-family: "SF Pro Display", "Inter", "Helvetica Neue", Arial, "PingFang SC", sans-serif;
}

.complete-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 120px 20px calc(env(safe-area-inset-bottom) + 40px);
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 320ms ease, transform 380ms cubic-bezier(0.22, 0.61, 0.36, 1);
}

.complete-page-entered {
  opacity: 1;
  transform: translateY(0);
}

.hero-circle {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  background: #10b981;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 0 0 rgba(16, 185, 129, 0.15),
    0 8px 15px rgba(16, 185, 129, 0.3);
}

.hero-check {
  font-size: 36px;
  color: #ffffff;
  font-weight: 700;
  line-height: 1;
}

.heading {
  margin-top: 24px;
  font-size: 52rpx;
  line-height: 78rpx;
  font-weight: 700;
  color: #1f2937;
}

.summary-card {
  margin-top: 40px;
  width: 100%;
  max-width: 283px;
  background: #ffffff;
  border-radius: 20px;
  padding: 20px;
  box-sizing: border-box;
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.06);
}

.summary-text {
  display: block;
  text-align: center;
  font-size: 36rpx;
  line-height: 54rpx;
  font-weight: 500;
  color: #6366f1;
}

.btn-home {
  position: fixed;
  left: 20px;
  right: 20px;
  bottom: calc(env(safe-area-inset-bottom) + 24px);
  height: 56px;
  border-radius: 16px;
  background: #6366f1;
  box-shadow: 0 4px 10px rgba(99, 102, 241, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-home-text {
  font-size: 34rpx;
  line-height: 52rpx;
  font-weight: 600;
  color: #ffffff;
}
