@import "../../styles/tabbar.wxss";

page {
  background: #f5f7fa;
  height: 100vh;
  font-family: "SF Pro Display", "Inter", "Helvetica Neue", Arial, "PingFang SC", sans-serif;
}

.me-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background: #f5f7fa;
}

.me-top-spacer {
  flex-shrink: 0;
  width: 100%;
  background: #f5f7fa;
}

.me-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

.me-content {
  padding: 6.8px 19.99px calc(24px + 7.994px + 66.858px + env(safe-area-inset-bottom) + 8px);
  box-sizing: border-box;
}

.me-avatar-wrap {
  display: flex;
  justify-content: center;
  width: 100%;
}

.me-avatar {
  width: 87.996px;
  height: 87.996px;
  border-radius: 44px;
  background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
  box-shadow: 0 8px 24px rgba(99, 102, 241, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.me-avatar-emoji {
  font-size: 36px;
  line-height: 54px;
  color: #0a0a0a;
}

.me-avatar.me-avatar--photo {
  background: #e5e7eb;
  padding: 0;
}

.me-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 44px;
  display: block;
}

.me-name-row {
  margin-top: 14px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  box-sizing: border-box;
}

.me-name {
  flex: 0 1 auto;
  max-width: 220px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  font-size: 20px;
  line-height: 30px;
  font-weight: 700;
  color: #1f2937;
}

.me-name-edit-hit {
  flex-shrink: 0;
  padding: 6px;
  margin: -6px -6px -6px 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.me-name-edit-icon {
  width: 20px;
  height: 20px;
  display: block;
}

.me-meta-row {
  margin-top: 6px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 5.993px;
  flex-wrap: wrap;
}

.me-badge {
  height: 29.984px;
  padding: 0 12px;
  border-radius: 24px;
  background: #eef2ff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.me-badge-text {
  font-size: 13px;
  line-height: 19.5px;
  font-weight: 500;
  color: #6366f1;
}

.me-dot {
  font-size: 13px;
  line-height: 19.5px;
  color: #d1d5db;
}

.me-id {
  font-size: 13px;
  line-height: 19.5px;
  font-weight: 400;
  color: #9ca3af;
}

.me-stats-row {
  margin-top: 20px;
  display: flex;
  flex-direction: row;
  gap: 11.996px;
  align-items: stretch;
}

.me-stat-card {
  flex: 1;
  min-width: 0;
  height: 129.167px;
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 13.997px 12px 14px;
  gap: 5.992px;
}

.me-stat-icon {
  width: 35.999px;
  height: 35.999px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.me-stat-icon--violet {
  background: #eef2ff;
}

.me-stat-icon--green {
  background: #ecfdf5;
}

.me-stat-icon--amber {
  background: #fef3c7;
}

.me-stat-icon--slate {
  background: #f1f5f9;
}

.me-stat-icon-img {
  width: 17.999px;
  height: 17.999px;
}

.me-stat-value {
  font-size: 22px;
  line-height: 22px;
  font-weight: 700;
  color: #1f2937;
}

.me-stat-label {
  font-size: 12px;
  line-height: 15.6px;
  font-weight: 400;
  color: #9ca3af;
  text-align: center;
}

.me-divider {
  margin-top: 20px;
  height: 0.995px;
  background: #e5e7eb;
  width: 100%;
}

.me-settings-card {
  margin-top: 20px;
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 67.995px;
  padding: 0 16px;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.me-settings-icon-wrap {
  width: 35.999px;
  height: 35.999px;
  border-radius: 11px;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.me-settings-icon {
  width: 19.99px;
  height: 19.99px;
}

.me-settings-title {
  flex: 1;
  margin-left: 13px;
  font-size: 16px;
  line-height: 24px;
  font-weight: 500;
  color: #1f2937;
}

.me-settings-chevron {
  width: 15.998px;
  height: 15.998px;
  flex-shrink: 0;
  opacity: 0.6;
}

.me-week-card {
  margin-top: 16px;
  padding: 17.999px 15.998px 16px;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
}

.me-week-heading {
  display: block;
  font-size: 15px;
  line-height: 22.5px;
  font-weight: 600;
  color: #374151;
  margin-bottom: 15.998px;
}

.me-week-bars {
  display: flex;
  flex-direction: row;
  gap: 7.994px;
  align-items: flex-end;
  width: 100%;
}

.me-week-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.me-week-min {
  font-size: 11px;
  line-height: 11px;
  font-weight: 400;
  color: #6b7280;
  margin-bottom: 4px;
}

.me-week-bar-wrap {
  width: 100%;
  height: 64px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
}

.me-week-bar {
  width: 39.05px;
  max-width: 100%;
  border-radius: 6px;
  /* 非当天：有数据也为中性灰，仅最后一根「今天」用主题蓝 */
  background: #d1d5db;
  flex-shrink: 0;
  transition: height 280ms ease-out;
}

.me-week-bar--empty {
  background: #e5e7eb;
}

.me-week-bar--today {
  background: #6366f1;
}

.me-week-day {
  margin-top: 6px;
  font-size: 10px;
  line-height: 10px;
  font-weight: 400;
  color: #9ca3af;
}

.me-week-day--today {
  font-weight: 600;
  color: #6366f1;
}

.me-signout {
  margin-top: 24px;
  height: 47.995px;
  border-radius: 14px;
  background: #fef2f2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.me-signout-text {
  font-size: 16px;
  line-height: 24px;
  font-weight: 500;
  color: #ef4444;
}

/* Study Settings 底部抽屉 Figma 71:477 */
.me-ss-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 10040;
}

.me-ss-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
}

.me-ss-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 85vh;
  overflow-y: auto;
  background: #ffffff;
  border-radius: 24px 24px 0 0;
  padding: 23.99px 19.99px calc(24px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transform: translateY(105%);
  transition: transform 0.32s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.me-ss-panel--enter {
  transform: translateY(0);
}

.me-pf-panel {
  min-height: 58vh;
  padding-bottom: calc(32px + env(safe-area-inset-bottom));
}

.me-ss-handle-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 19.99px;
}

.me-ss-handle {
  width: 35.999px;
  height: 3.991px;
  border-radius: 2px;
  background: #e5e7eb;
}

.me-ss-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
}

.me-ss-title {
  font-size: 18px;
  line-height: 27px;
  font-weight: 700;
  color: #1f2937;
}

.me-ss-close {
  width: 31.996px;
  height: 31.996px;
  border-radius: 16px;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.me-ss-close-icon {
  width: 15.998px;
  height: 15.998px;
}

.me-ss-section {
  margin-bottom: 28px;
}

.me-ss-label {
  display: block;
  font-size: 15px;
  line-height: 22.5px;
  font-weight: 500;
  color: #374151;
  margin-bottom: 11.996px;
}

.me-ss-stepper {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 15.998px;
}

.me-ss-step-btn {
  width: 39.99px;
  height: 39.99px;
  border-radius: 12px;
  background: #eef2ff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.me-ss-step-icon {
  width: 17.999px;
  height: 17.999px;
}

.me-ss-step-val {
  flex: 1;
  text-align: center;
  font-size: 22px;
  line-height: 33px;
  font-weight: 700;
  color: #1f2937;
}

.me-ss-done {
  margin-top: 8px;
  width: 100%;
  height: 51.997px;
  border-radius: 16px;
  background: #6366f1;
  box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.me-ss-done-text {
  font-size: 17px;
  line-height: 25.5px;
  font-weight: 600;
  color: #ffffff;
}

.me-pf-avatar-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
  padding: 0 4px;
}

.me-pf-avatar-ring {
  width: 87.996px;
  height: 87.996px;
  border-radius: 44px;
  background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.me-pf-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.me-pf-avatar-ph {
  font-size: 36px;
  line-height: 54px;
}

.me-pf-choose-btn {
  margin: 0;
  padding: 8px 18px;
  line-height: 1.35;
  font-size: 14px;
  font-weight: 500;
  color: #6366f1;
  background: #eef2ff;
  border: none;
  border-radius: 999px;
}

.me-pf-choose-btn::after {
  border: none;
}

.me-pf-nick {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  box-sizing: border-box;
  border-radius: 12px;
  background: #f3f4f6;
  font-size: 16px;
  color: #1f2937;
}

