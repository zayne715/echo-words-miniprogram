@import "../../styles/example-memory-anchor.wxss";

page {
  background: #f5f7fa;
  min-height: 100vh;
  font-family: "SF Pro Display", "Inter", "Helvetica Neue", Arial, "PingFang SC", sans-serif;
}

.detail-page {
  height: 100vh;
  transform: translateX(100%);
  transition: transform 220ms ease-out;
  box-sizing: border-box;
  background: #f5f7fa;
}

.detail-page-entered {
  transform: translateX(0);
}

.page-scroll {
  height: 100vh;
}

.page-scroll-content {
  padding-top: 14px;
  padding-bottom: 150px;
  box-sizing: border-box;
}

.top-bar {
  height: 40px;
  padding: 0 16px;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  margin-top: 0;
  gap: 12px;
}

.circle-btn {
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background: rgba(107, 114, 128, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-btn-light {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  opacity: 0.3;
  background: rgba(107, 114, 128, 0.08);
}

.circle-icon {
  width: 22px;
  height: 22px;
}

.reply-wrap {
  width: 18px;
  height: 18px;
  position: relative;
}

.reply-base {
  width: 18px;
  height: 18px;
}

.reply-arrow {
  width: 14px;
  height: 12px;
  position: absolute;
  left: 2px;
  top: 4px;
}

.header-progress {
  flex: 1;
  min-width: 0;
  height: 30px;
  margin: 0;
  background: #e5e7eb;
  border-radius: 15px;
  position: relative;
  overflow: hidden;
}

.header-progress-fill {
  height: 30px;
  border-radius: 15px;
  background: #6366f1;
  transition: width 220ms ease;
}

.header-progress-text {
  position: absolute;
  left: 50%;
  top: 5px;
  z-index: 1;
  transform: translateX(-50%);
  font-size: 26rpx;
  line-height: 40rpx;
  color: #6b7280;
  font-weight: 500;
}

.content-card {
  margin: 28px 16px 0;
  width: calc(100vw - 32px);
  box-sizing: border-box;
}

.word-title-row {
  height: 38px;
  display: flex;
  align-items: center;
}

.word-audio {
  width: 20px;
  height: 20px;
}

.word-title {
  margin-left: 8px;
  font-size: 68rpx;
  line-height: 74rpx;
  color: #1f2937;
  font-weight: 700;
}

.word-phonetic {
  margin-top: 8px;
  font-size: 34rpx;
  line-height: 52rpx;
  color: #9ca3af;
}

.word-meaning-row {
  margin-top: 6px;
  display: flex;
  align-items: center;
}

.word-pos {
  font-size: 38rpx;
  line-height: 58rpx;
  color: #4b5563;
  font-weight: 500;
}

.word-meaning-cn {
  margin-left: 10rpx;
  font-size: 38rpx;
  line-height: 58rpx;
  color: #4b5563;
  font-weight: 500;
}

.tab-card {
  margin-top: 18px;
  width: 100%;
  height: 483px;
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 2px 16px rgba(99, 102, 241, 0.06);
  overflow: hidden;
}

.tab-head {
  height: 47px;
  display: flex;
  border-bottom: 0.7px solid #f3f4f6;
}

.tab-btn {
  width: 33.3333%;
  height: 46px;
  border-bottom: 1.4px solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-active {
  background: #eef2ff;
  border-bottom-color: #6366f1;
}

.tab-btn-text {
  font-size: 28rpx;
  line-height: 42rpx;
  color: #6b7280;
  font-weight: 500;
}

.tab-text-active {
  color: #6366f1;
}

.tab-body {
  padding: 16px;
  box-sizing: border-box;
}

.line-item {
  width: 100%;
}

.line-en {
  font-size: 32rpx;
  line-height: 54rpx;
  color: #374151;
}

.hl {
  color: #ff5555;
}

.line-cn {
  margin-top: 2px;
  display: block;
  font-size: 30rpx;
  line-height: 54rpx;
  color: #9ca3af;
}

.inf-row {
  display: flex;
  align-items: center;
  margin-bottom: 2px;
}

.inf-key {
  width: 76px;
  font-size: 30rpx;
  line-height: 54rpx;
  color: #9ca3af;
}

.inf-val {
  margin-left: 18px;
  font-size: 32rpx;
  line-height: 54rpx;
  color: #374151;
}

.col-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 22rpx;
  width: 100%;
  box-sizing: border-box;
}

.col-en {
  font-size: 32rpx;
  line-height: 54rpx;
  color: #374151;
  width: 100%;
  word-break: break-word;
}

.col-cn {
  margin-left: 0;
  font-size: 30rpx;
  line-height: 54rpx;
  color: #9ca3af;
  width: 100%;
  word-break: break-word;
}

.bottom-cta-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 104px;
  padding: 12px 16px calc(env(safe-area-inset-bottom) + 12px);
  box-sizing: border-box;
  background: #f5f7fa;
}

.bottom-cta {
  width: 100%;
  height: 56px;
  border-radius: 16px;
  background: #6366f1;
  box-shadow: 0 4px 10px rgba(99, 102, 241, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: center center;
}

.bottom-cta-text {
  font-size: 34rpx;
  line-height: 52rpx;
  color: #fff;
  font-weight: 600;
}

.btn-pressed {
  transform: scale(0.97);
  transition: transform 70ms cubic-bezier(0.22, 0.61, 0.36, 1);
}

.btn-release {
  transform: scale(1);
  transition: transform 70ms cubic-bezier(0.22, 0.61, 0.36, 1);
}

.btn-disabled {
  pointer-events: none;
}

/* iPhone Pro 视觉适配：让流程页控件与内容更饱满 */
.page-scroll-content {
  padding-bottom: 168px;
}

.top-bar {
  height: 44px;
  padding: 0 18px;
  gap: 14px;
}

.circle-btn {
  width: 44px;
  height: 44px;
  border-radius: 22px;
}

.circle-btn-light {
  width: 40px;
  height: 40px;
  border-radius: 20px;
}

.circle-icon {
  width: 24px;
  height: 24px;
}

.header-progress {
  height: 32px;
  border-radius: 16px;
}

.header-progress-fill {
  height: 32px;
  border-radius: 16px;
}

.header-progress-text {
  top: 6px;
  font-size: 28rpx;
  line-height: 40rpx;
}

.content-card {
  margin: 32px 18px 0;
  width: calc(100vw - 36px);
}

.word-audio {
  width: 22px;
  height: 22px;
}

.word-title {
  font-size: 74rpx;
  line-height: 80rpx;
}

.word-phonetic {
  font-size: 36rpx;
  line-height: 56rpx;
}

.word-pos,
.word-meaning-cn {
  font-size: 40rpx;
  line-height: 62rpx;
}

.tab-card {
  margin-top: 22px;
  min-height: 500px;
  height: auto;
  border-radius: 22px;
}

.tab-head {
  height: 52px;
}

.tab-btn {
  height: 51px;
}

.tab-btn-text {
  font-size: 30rpx;
}

.tab-body {
  padding: 18px;
}

.line-en,
.col-en,
.inf-val {
  font-size: 34rpx;
  line-height: 58rpx;
}

.line-cn,
.col-cn,
.inf-key {
  font-size: 32rpx;
  line-height: 56rpx;
}

.bottom-cta-wrap {
  height: 112px;
  padding: 14px 18px calc(env(safe-area-inset-bottom) + 14px);
}

.bottom-cta {
  height: 60px;
  border-radius: 18px;
}

.bottom-cta-text {
  font-size: 36rpx;
}

.word-pos,
.word-meaning-cn {
  font-size: 34rpx;
  line-height: 52rpx;
}

/* Collocations：上下排列，词组与译文间距统一，不做整列对齐 */
.col-row {
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.col-en,
.col-cn {
  line-height: 52rpx;
}
